# Optional: enable true cross-device online play via Supabase Realtime.
# Without these, "Online" falls back to same-device (two browser tabs) mode.
#
# Create a free project at https://supabase.com, then copy these from
# Project Settings → API. No database tables are required — online play uses
# ephemeral Realtime broadcast channels.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
